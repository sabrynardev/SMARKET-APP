rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function protectedUserFieldsChanged() {
      return request.resource.data.diff(resource.data).changedKeys().hasAny([
        "plan",
        "subscriptionStatus",
        "planStartedAt",
        "planExpiresAt",
        "storeProductId",
        "purchaseToken",
        "subscriptionPlatform",
        "ultimate",
        "admin",
        "role"
      ]);
    }

    function protectedUserFieldsOnCreate() {
      return request.resource.data.keys().hasAny([
        "plan",
        "subscriptionStatus",
        "planStartedAt",
        "planExpiresAt",
        "storeProductId",
        "purchaseToken",
        "subscriptionPlatform",
        "ultimate",
        "admin",
        "role"
      ]);
    }

    // Cada usuario autenticado so pode acessar o proprio perfil e seus dados financeiros.
    match /usuarios/{userId} {
      allow read, write: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      // Campos de assinatura e claims so podem ser alterados via Admin SDK/Cloud Functions.
      allow create: if isOwner(userId) && !protectedUserFieldsOnCreate();
      allow update: if isOwner(userId) && !protectedUserFieldsChanged();
      allow delete: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
